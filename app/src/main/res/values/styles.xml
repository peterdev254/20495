<?xml version="1.0" encoding="utf-8"?>
<!--
    STYLES — styles.xml
    Centralized styles for the StyleNest application.
    This file defines the visual language for buttons, text, and components.
-->
<resources>

    <!--  == THEME / BASE STYLES ==  -->

    <style name="StyleNest" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/gold</item>
    </style>

    <!--  == TEXT STYLES ==  -->

    <!-- Standard Section Label (Used in Home and Profile) -->
    <style name="StyleNest.SectionLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/mid_gray</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <!-- Page Heading -->
    <style name="StyleNest.Heading">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Bottom Nav Text Style -->
    <style name="BottomNavTextActive">
        <item name="android:textSize">10sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!--  ══ BUTTON STYLES ══  -->

    <!-- Primary Brand Button (Black Background) -->
    <style name="StyleNest.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/black</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="cornerRadius">4dp</item>
    </style>

    <!-- Outlined Button (Bordered) -->
    <style name="StyleNest.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/dark_gray</item>
        <item name="strokeColor">@color/border_gray</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">4dp</item>
    </style>

    <!--  ══ COMPONENT STYLES ══  -->

    <!-- Category/Size Selection Chip -->
    <style name="StyleNest.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">4dp</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipStrokeColor">@color/border_gray</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>
