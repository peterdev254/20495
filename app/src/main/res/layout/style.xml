
    <!--
        STYLES & THEMES — styles.xml
        StyleNest theme: Black/White/Gold.
        Place in res/values/
     -->
<resources>
    <!--  ═══════════════════════════════════════════════
             APP THEME
             Extends Material3 (DayNight) with brand overrides.
        ════════════════════════════════════════════════  -->
    <style name="Theme.StyleNest" parent="Theme.Material3.DayNight.NoActionBar">
        <!--  Brand primary = black  -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/dark_gray</item>
        <item name="colorOnPrimary">@color/white</item>
        <!--  Accent = gold  -->
        <item name="colorSecondary">@color/gold</item>
        <item name="colorOnSecondary">@color/black</item>
        <!--  Window  -->
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <!--  Typography — clean sans-serif  -->
        <item name="android:fontFamily">sans-serif</item>
        <!--  Chip style overrides (category + size chips)  -->
        <item name="chipStyle">@style/StyleNest.Chip</item>
        <!--  Text input style  -->
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
    </style>
    <!--  ═══════════════════════════════════════════════
             SPLASH (full black screen, no action bar)
        ════════════════════════════════════════════════  -->
    <style name="Theme.StyleNest.Splash" parent="Theme.StyleNest">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/black</item>
    </style>
    <!--  ═══════════════════════════════════════════════
             BOTTOM NAV TEXT
        ════════════════════════════════════════════════  -->
    <style name="BottomNavTextActive">
        <item name="android:textSize">9sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <!--  ═══════════════════════════════════════════════
             CHIP — Category and Size selectors
        ════════════════════════════════════════════════  -->
    <style name="StyleNest.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@drawable/chip_bg_selector</item>
        <item name="android:textColor">@drawable/chip_text_selector</item>
        <item name="chipCornerRadius">2dp</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipStrokeColor">@color/border_gray</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <!--  ═══════════════════════════════════════════════
             PRIMARY BUTTON (black bg, white text)
        ════════════════════════════════════════════════  -->
    <style name="StyleNest.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/black</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">2dp</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <!--  ═══════════════════════════════════════════════
             SECONDARY / OUTLINED BUTTON
        ════════════════════════════════════════════════  -->
    <style name="StyleNest.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/dark_gray</item>
        <item name="android:textSize">12sp</item>
        <item name="strokeColor">@color/border_gray</item>
        <item name="cornerRadius">2dp</item>
    </style>
    <!--  ═══════════════════════════════════════════════
             SECTION LABEL (caps, small, gold or gray)
        ════════════════════════════════════════════════  -->
    <style name="StyleNest.SectionLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/mid_gray</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>
</resources>