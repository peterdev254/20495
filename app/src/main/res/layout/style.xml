<?xml version="1.0" encoding="utf-8"?>
<!--
    STYLE GUIDE - style.xml
    A visual guide to the application's styles.
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    tools:context=".style">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            style="@style/StyleNest.Heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STYLE GUIDE" />

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:background="@color/gold" />

        <!-- Buttons Section -->
        <TextView
            style="@style/StyleNest.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="0dp"
            android:text="Buttons" />

        <Button
            style="@style/StyleNest.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Primary Button" />

        <Button
            style="@style/StyleNest.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Outlined Button" />

        <!-- Chips Section -->
        <TextView
            style="@style/StyleNest.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="0dp"
            android:text="Chips" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                style="@style/StyleNest.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selected"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                style="@style/StyleNest.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unselected" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Typography Section -->
        <TextView
            style="@style/StyleNest.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="0dp"
            android:text="Typography" />

        <TextView
            style="@style/StyleNest.Heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This is a Heading" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Standard body text with dark gray coloring."
            android:textColor="@color/dark_gray"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
