
    <!--
        CART — fragment_cart.xml
        Two states handled in CartFragment:
          • EMPTY  — show emptyStateGroup, hide cartGroup
          • HAS ITEMS — hide emptyStateGroup, show cartGroup

        cartGroup contains:
          • RecyclerView of cart items
          • Order summary card (subtotal, delivery, total)
          • Checkout / Place Order button at bottom (sticky)
     -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white">
    <!--  ══ HEADING ══  -->
    <TextView android:id="@+id/tvCartHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cart" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/black" android:layout_marginStart="16dp" android:layout_marginTop="16dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <TextView android:id="@+id/tvCartCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="(0)" android:textSize="14sp" android:textColor="@color/mid_gray" android:layout_marginStart="6dp" app:layout_constraintStart_toEndOf="@+id/tvCartHeading" app:layout_constraintBaseline_toBaselineOf="@+id/tvCartHeading"/>
    <!--  ══════════ EMPTY STATE ══════════  -->
    <LinearLayout android:id="@+id/llEmptyCart" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:padding="48dp" android:visibility="gone" app:layout_constraintTop_toBottomOf="@+id/tvCartHeading" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛍️" android:textSize="48sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Your cart is empty" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/dark_gray" android:layout_marginTop="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Browse our collections to find something you love." android:textSize="12sp" android:textColor="@color/mid_gray" android:gravity="center" android:layout_marginTop="6dp"/>
        <Button android:id="@+id/btnBrowseNow" android:layout_width="wrap_content" android:layout_height="44dp" android:text="BROWSE NOW" android:textSize="12sp" android:textStyle="bold" android:letterSpacing="0.15" android:backgroundTint="@color/black" android:textColor="@color/white" android:layout_marginTop="20dp"/>
    </LinearLayout>
    <!--  ══════════ CART CONTENT ══════════  -->
    <!--  Scrollable portion: item list + summary  -->
    <androidx.core.widget.NestedScrollView android:id="@+id/nsvCartContent" android:layout_width="0dp" android:layout_height="0dp" android:visibility="visible" app:layout_constraintTop_toBottomOf="@+id/tvCartHeading" app:layout_constraintBottom_toTopOf="@+id/btnPlaceOrder" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingTop="12dp">
            <!--  Cart items list  -->
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvCartItems" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="16dp" android:paddingEnd="16dp" android:nestedScrollingEnabled="false" app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
            <!--  ══ Order Summary Card ══  -->
            <LinearLayout android:id="@+id/llOrderSummary" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@color/light_gray" android:padding="16dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginTop="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Order Summary" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/mid_gray" android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="10dp"/>
                <!--  Subtotal row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:id="@+id/tvSubtotalLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Subtotal (0 items)" android:textSize="12sp" android:textColor="@color/dark_gray"/>
                    <TextView android:id="@+id/tvSubtotalValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KSh 0" android:textSize="12sp" android:textColor="@color/dark_gray"/>
                </LinearLayout>
                <!--  Delivery row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Delivery" android:textSize="12sp" android:textColor="@color/dark_gray"/>
                    <TextView android:id="@+id/tvDeliveryValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KSh 300" android:textSize="12sp" android:textColor="@color/dark_gray"/>
                </LinearLayout>
                <!--  Divider  -->
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_gray" android:layout_marginBottom="10dp"/>
                <!--  Total row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black"/>
                    <TextView android:id="@+id/tvTotalValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KSh 0" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/black"/>
                </LinearLayout>
            </LinearLayout>
            <!--  ══ Checkout / Delivery Form ══  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@color/light_gray" android:padding="16dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginTop="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delivery Details" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/mid_gray" android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="12dp"/>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Full Name" android:layout_marginBottom="10dp" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etFullName" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textPersonName" android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Phone Number" android:layout_marginBottom="10dp" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etPhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="phone" android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Delivery Address" android:layout_marginBottom="10dp" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etAddress" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textPostalAddress" android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>
                <!--  Payment method spinner  -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Payment Method" android:textSize="10sp" android:textColor="@color/mid_gray" android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerPayment" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/spinner_background" android:entries="@array/payment_methods" android:layout_marginBottom="4dp"/>
            </LinearLayout>
            <!--  spacer before sticky button  -->
            <View android:layout_width="match_parent" android:layout_height="16dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <!--  ══ Sticky Place Order Button ══  -->
    <Button android:id="@+id/btnPlaceOrder" android:layout_width="0dp" android:layout_height="52dp" android:text="PLACE ORDER" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.15" android:backgroundTint="@color/black" android:textColor="@color/white" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="16dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>