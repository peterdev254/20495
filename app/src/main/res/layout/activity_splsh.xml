
    <!--
        SPLASH SCREEN — activity_splash.xml
        Full-screen branded entry screen. Displayed for 2–3 seconds, then
        navigates to MainActivity via Handler.postDelayed().
        Background: @color/black  |  Logo gold text centred.
     -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/black">
    <!--  Star / brand icon  -->
    <TextView android:id="@+id/tvSplashStar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✦" android:textSize="48sp" android:textColor="@color/gold" app:layout_constraintBottom_toTopOf="@+id/tvSplashLogo" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="12dp"/>
    <!--  Brand name  -->
    <TextView android:id="@+id/tvSplashLogo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STYLENEST" android:textSize="32sp" android:textColor="@color/gold" android:textStyle="bold" android:letterSpacing="0.25" app:layout_constraintBottom_toTopOf="@+id/tvSplashTagline" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="8dp"/>
    <!--  Tagline  -->
    <TextView android:id="@+id/tvSplashTagline" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nairobi · Urban Fashion" android:textSize="11sp" android:textColor="@color/mid_gray" android:letterSpacing="0.2" android:textAllCaps="true" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <!--  Enter Store button  -->
    <Button android:id="@+id/btnEnterStore" android:layout_width="180dp" android:layout_height="48dp" android:text="ENTER STORE" android:textSize="12sp" android:textColor="@color/black" android:textStyle="bold" android:letterSpacing="0.15" android:backgroundTint="@color/gold" app:layout_constraintTop_toBottomOf="@+id/tvSplashTagline" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="48dp"/>
    <!--  Footer  -->
    <TextView android:id="@+id/tvSplashFooter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Est. 2020 · Westlands, Nairobi" android:textSize="10sp" android:textColor="@color/dark_gray" android:letterSpacing="0.1" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="32dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>