<?xml version="1.0" encoding="utf-8"?>
<!--
    PRODUCT DETAIL - fragment_productdetail.xml
    Scrollable detail view for a single product.
    Structure:
      - Large image hero (black bg) with tag badge + wishlist button
      - Category label, Product name, Price
      - Description
      - Size selector (RecyclerView horizontal OR ChipGroup)
      - "Add to Cart" primary button
      - "Add to Wishlist" secondary button
      - Shipping info card (3 bullet rows)
 -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!--  == Back button ==  -->
        <Button
            android:id="@+id/btnBack"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:background="?attr/selectableItemBackground"
            android:text="@string/back_button"
            android:textColor="@color/dark_gray"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!--  == Hero Image ==  -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="240dp">

            <ImageView
                android:id="@+id/ivProductDetail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/black"
                android:contentDescription="Product detail image"
                android:padding="0dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_blazer_real" />

            <!--  Tag badge - top-left  -->
            <TextView
                android:id="@+id/tvDetailTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="14dp"
                android:background="@color/gold"
                android:letterSpacing="0.1"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:text="@string/tag_new"
                android:textColor="@color/black"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!--  Wishlist button - top-right  -->
            <ImageButton
                android:id="@+id/ibDetailWishlist"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Add to wishlist"
                app:tint="@color/white" />
        </FrameLayout>

        <!--  == Product Info ==  -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/tvDetailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.2"
                android:text="CATEGORY"
                android:textAllCaps="true"
                android:textColor="@color/gold"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Product Name"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="KSh 0"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingMultiplier="1.6"
                android:text="Product description goes here."
                android:textColor="@color/dark_gray"
                android:textSize="13sp" />

            <!--  == Size Selector ==  -->
            <TextView
                android:id="@+id/tvSizeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.1"
                android:text="@string/label_select_size"
                android:textAllCaps="true"
                android:textColor="@color/mid_gray"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupSizes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:selectionRequired="false"
                app:singleSelection="true">
                <!--
                                    Chips are inflated programmatically:
                                        product.sizes.forEach { size ->
                                            val chip = Chip(context)
                                            chip.text = size
                                            chip.isCheckable = true
                                            chipGroupSizes.addView(chip)
                                        }
                                 -->
            </com.google.android.material.chip.ChipGroup>

            <!--  == Add to Cart ==  -->
            <Button
                android:id="@+id/btnAddToCart"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/dark_gray"
                android:enabled="false"
                android:letterSpacing="0.15"
                android:text="@string/btn_select_size"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!--  == Wishlist secondary ==  -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToWishlist"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="10dp"
                android:text="@string/btn_wishlist_add"
                android:textColor="@color/dark_gray"
                android:textSize="12sp"
                app:strokeColor="@color/border_gray" />

            <!--  == Shipping Info ==  -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="28dp"
                android:background="@color/light_gray"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="6dp"
                    android:text="@string/shipping_free_delivery"
                    android:textColor="@color/dark_gray"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="6dp"
                    android:text="@string/shipping_returns"
                    android:textColor="@color/dark_gray"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/shipping_authentic"
                    android:textColor="@color/dark_gray"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
