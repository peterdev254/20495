<?xml version="1.0" encoding="utf-8"?>
<!--
    ORDER HISTORY ROW - item_order.xml
    Used in the Profile screen's Order History RecyclerView.
 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@color/light_gray"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <!--  Order info  -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvOrderId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#SN-0041"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOrderMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="28 May 2026 · 2 items"
            android:textColor="@color/mid_gray"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvOrderTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="KSh 5,000"
            android:textColor="@color/dark_gray"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!--  Status badge  -->
    <TextView
        android:id="@+id/tvOrderStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/badge_delivered"
        android:letterSpacing="0.1"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:text="@string/status_delivered"
        android:textColor="#2E7D32"
        android:textSize="9sp"
        android:textStyle="bold" />
</LinearLayout>
