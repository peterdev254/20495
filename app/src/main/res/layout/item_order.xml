
    <!
        ORDER HISTORY ROW — item_order.xml
        Used in the Profile screen's Order History RecyclerView.
     -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/light_gray" android:padding="14dp" android:gravity="center_vertical" android:layout_marginBottom="8dp">
    <!--  Order info  -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvOrderId" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#SN-0041" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black"/>
        <TextView android:id="@+id/tvOrderMeta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="28 May 2026 · 2 items" android:textSize="11sp" android:textColor="@color/mid_gray" android:layout_marginTop="2dp"/>
        <TextView android:id="@+id/tvOrderTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KSh 5,000" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/dark_gray" android:layout_marginTop="4dp"/>
    </LinearLayout>
    <!--  Status badge  -->
    <TextView android:id="@+id/tvOrderStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DELIVERED" android:textSize="9sp" android:textStyle="bold" android:textColor="#2E7D32" android:letterSpacing="0.1" android:background="@drawable/badge_delivered" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="4dp" android:paddingBottom="4dp"/>
</LinearLayout>