
    <!__
        ORDER CONFIRMATION — fragment_order_confirmation.xml
        Shown after a successful order placement.
        Centred vertically in the screen.
        Navigate here from CartFragment after btnPlaceOrder is tapped.
     -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white" android:padding="32dp">
    <!--  Star icon  -->
    <TextView android:id="@+id/tvConfirmStar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✦" android:textSize="56sp" android:textColor="@color/gold" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@+id/tvConfirmTitle" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintVertical_chainStyle="packed" android:layout_marginBottom="16dp"/>
    <TextView android:id="@+id/tvConfirmTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Order Confirmed!" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/black" android:letterSpacing="0.05" app:layout_constraintTop_toBottomOf="@+id/tvConfirmStar" app:layout_constraintBottom_toTopOf="@+id/tvConfirmSubtitle" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/tvConfirmSubtitle" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Your order is being packed.\nExpect delivery within 2–3 working days." android:textSize="13sp" android:textColor="@color/dark_gray" android:gravity="center" android:lineSpacingMultiplier="1.6" app:layout_constraintTop_toBottomOf="@+id/tvConfirmTitle" app:layout_constraintBottom_toTopOf="@+id/tvOrderNumber" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="20dp"/>
    <!--  Order number pill  -->
    <TextView android:id="@+id/tvOrderNumber" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#SN-0042" android:textSize="12sp" android:textColor="@color/mid_gray" android:letterSpacing="0.1" android:background="@color/light_gray" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="12dp" android:paddingBottom="12dp" app:layout_constraintTop_toBottomOf="@+id/tvConfirmSubtitle" app:layout_constraintBottom_toTopOf="@+id/btnContinueShopping" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="28dp"/>
    <Button android:id="@+id/btnContinueShopping" android:layout_width="wrap_content" android:layout_height="48dp" android:text="CONTINUE SHOPPING" android:textSize="12sp" android:textStyle="bold" android:letterSpacing="0.15" android:backgroundTint="@color/black" android:textColor="@color/white" android:paddingStart="32dp" android:paddingEnd="32dp" app:layout_constraintTop_toBottomOf="@+id/tvOrderNumber" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>